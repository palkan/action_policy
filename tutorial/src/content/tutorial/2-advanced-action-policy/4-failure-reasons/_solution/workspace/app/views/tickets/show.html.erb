<div class="page-header">
  <h1><%= @ticket.title %></h1>
  <div class="inline-actions">
    <% if allowed_to?(:edit?, @ticket) %>
      <%= link_to "Edit", edit_ticket_path(@ticket), class: "btn" %>
    <% end %>
    <% if allowed_to?(:destroy?, @ticket) %>
      <%= button_to "Delete", @ticket, method: :delete, class: "btn btn--danger", data: {turbo_confirm: "Are you sure?"} %>
    <% end %>
    <% if !@ticket.resolved? %>
      <% if allowed_to?(:resolve?, @ticket) %>
        <%= button_to "Resolve", resolve_ticket_path(@ticket), method: :patch, class: "btn btn--success" %>
      <% elsif allowed_to?(:resolve?, Ticket) %>
        <button disabled class="btn btn--success" title="<%= allowance_to(:resolve?, @ticket).reasons.full_messages.to_sentence %>">Resolve</button>
      <% end %>
    <% end %>
  </div>
</div>

<div class="card mb-md">
  <div class="card__body">
    <p><%= @ticket.description %></p>
    <div class="mt-md text-sm text-muted">
      Status: <span class="badge badge--<%= status_badge_class(@ticket.status) %>"><%= @ticket.status.titleize %></span>
      &middot; Level: <%= @ticket.escalation_level %>
      &middot; Created by: <strong><%= @ticket.user.name %></strong>
      <% if @ticket.agent %>
        &middot; Assigned to: <strong><%= @ticket.agent.name %></strong>
      <% end %>
    </div>
  </div>
</div>

<h2>Comments</h2>

<% @comments.each do |comment| %>
  <%= render comment %>
<% end %>

<% if allowed_to?(:create?, Comment, context: {ticket: @ticket}) %>
  <div class="card mt-md">
    <div class="card__header">
      <h3>Add a comment</h3>
    </div>
    <div class="card__body">
      <%= render "comments/form", ticket: @ticket, comment: Comment.new %>
    </div>
  </div>
<% end %>
